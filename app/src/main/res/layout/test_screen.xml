<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:id="@+id/main2"
    android:background="#F5F5F5">

    <!-- Верхняя панель: прогресс-бар сессии -->
    <ProgressBar
        android:id="@+id/quiz_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="20"
        android:max="100"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/quiz_coin_layout"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"/>

    <!-- Текущие монетки (отображаются прямо во время теста) -->
    <LinearLayout
        android:id="@+id/quiz_coin_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:drawable/toast_frame"
        android:backgroundTint="#FFF9C4"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/btn_star_big_on" />

        <TextView
            android:id="@+id/tv_quiz_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="150"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:textColor="#333333"/>
    </LinearLayout>

    <!-- Карточка с вопросом (иностранное слово) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_quiz_question"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/quiz_coin_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Как переводится слово?"
                android:textSize="14sp"
                android:textColor="#999999"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_quiz_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#333333"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Блок с вариантами ответов -->
    <LinearLayout
        android:id="@+id/answers_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_quiz_question"
        app:layout_constraintVertical_bias="0.6">

        <Button
            android:id="@+id/btn_answer1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Разработчик"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_answer2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Дизайнер"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_answer3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Учитель"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_answer4"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Водитель"
            android:textAllCaps="false"
            android:textSize="16sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>